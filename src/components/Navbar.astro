---
// Top navigation — Calm Premium. Logo, section links, theme + language toggles,
// primary CTA, mobile burger. Language is a real link (good for SEO/crawlers).
import Icon from "./landing/Icon.astro";
import { useTranslations, altLangPath } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const base = `/${lang}`;
const to: Lang = lang === "ar" ? "en" : "ar";
const langHref = altLangPath(Astro.url.pathname, to);
const langLabel = to === "ar" ? "ع" : "EN";
const links = [
  { href: `${base}#features`, label: t("nav.features") },
  { href: `${base}#how`, label: lang === "ar" ? "كيف يعمل" : "How it works" },
  { href: `${base}#privacy`, label: lang === "ar" ? "الخصوصية" : "Privacy" },
  { href: `${base}#pricing`, label: t("nav.pricing") },
  { href: `${base}#faq`, label: lang === "ar" ? "الأسئلة" : "FAQ" },
];
---
<header class="nav" id="nav">
  <div class="wrap nav-in">
    <a class="brand" href={base} aria-label="Saver home">
      <img class="brand-logo" src="/icon.png" width="34" height="34" alt="" aria-hidden="true" />
      Saver
    </a>
    <nav class="nav-links" id="navLinks" aria-label="Primary">
      {links.map((l) => (<a href={l.href}>{l.label}</a>))}
    </nav>
    <div class="nav-actions">
      <button class="toggle" id="themeToggle" type="button" aria-label="Toggle theme">
        <span id="themeIcon"><Icon name="moon" /></span>
      </button>
      <a class="toggle lang-t" href={langHref} hreflang={to} aria-label={`Switch language to ${to === "ar" ? "العربية" : "English"}`}>
        <Icon name="globe" /><span>{langLabel}</span>
      </a>
      <a class="btn btn-primary btn-sm" href={`${base}/download`}>{t("cta.try")}</a>
      <button class="toggle nav-burger" id="burger" type="button" aria-label="Menu"><Icon name="burger" /></button>
    </div>
  </div>
</header>
