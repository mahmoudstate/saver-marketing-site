---
// Real app bottom nav: Home · Bills · [+] · Activity · Profile (see BottomNav.jsx).
import Icon from "../Icon.astro";
const { active = "home" } = Astro.props as { active?: string };
const on = (t: string) => (active === t ? "it on" : "it");
---
<div class="appnav">
  <div class={on("home")}><Icon name="home" /></div>
  <div class={on("bills")}><Icon name="bills" /></div>
  <div class="fab"><Icon name="plus" stroke-width="2.4" /></div>
  <div class={on("activity")}><Icon name="activity" /></div>
  <div class={on("profile")}><Icon name="you" /></div>
</div>
