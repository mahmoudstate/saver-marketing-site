---
// Goals — ported from the app (src/screens/Goals.jsx): mint hero with total
// saved, per-goal cards (progress), and the "frozen & safe" banner.
import Icon from "../Icon.astro";
import ScreenNav from "./ScreenNav.astro";
const { s } = Astro.props as { s: Record<string, string> };
const goals = [
  { name: s.goalLaptop, saved: "600", of: "1,800", pct: 33 },
  { name: s.goalHoliday, saved: "280", of: "900", pct: 31 },
];
---
<div class="content padnav">
  <div class="hero" style="min-height:auto">
    <div class="toprow"><div class="hib"><Icon name="back" /></div><div style="font-size:17px;font-weight:800">{s.goalsTitle}</div><div class="grow"></div><div class="hib"><Icon name="plus" /></div></div>
    <div class="lbl">{s.savedToward}</div>
    <div class="big tnum"><span class="cur">£</span>880</div>
    <div class="sub">{s.twoActive} &nbsp;·&nbsp; {s.frozenSafe}</div>
  </div>
  {goals.map((g) => (
    <div class="bcard">
      <div class="top"><span class="circ" style="width:42px;height:42px;border-radius:13px;background:var(--acDim);color:var(--acText)"><Icon name="target" /></span><div class="nm">{g.name}</div><div class="pct">{g.pct}%</div></div>
      <div class="nums"><div class="a tnum">£{g.saved}</div><div class="b tnum">{s.of} £{g.of}</div></div>
      <div class="pbar"><i style={`width:${g.pct}%;background:linear-gradient(90deg,var(--ac),var(--ac2))`}></i></div>
    </div>
  ))}
  <div style="display:flex;align-items:center;gap:10px;background:var(--acDim);color:var(--acText);border-radius:14px;padding:12px 14px;margin-top:4px">
    <Icon name="lock" /><span style="font-weight:700;font-size:13px">{s.frozenAndSafe}</span><b class="tnum" style="margin-inline-start:auto;font-size:14px">£880</b>
  </div>
</div>
<ScreenNav active="home" />
