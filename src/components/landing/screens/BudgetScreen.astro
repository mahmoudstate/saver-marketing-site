---
import Icon from "../Icon.astro";
import ScreenNav from "./ScreenNav.astro";
const { s } = Astro.props as { s: Record<string, string> };
---
<div class="scr-top"><div class="scr-sec-t">{s.budgetTitle}</div><div class="scr-eye"><Icon name="budget" /></div></div>
<div class="scr-card" style="display:flex;flex-direction:column;align-items:center;gap:6px;padding:18px 14px">
  <div class="ring-c">
    <svg class="ring" viewBox="0 0 120 120">
      <circle class="trk" cx="60" cy="60" r="50"></circle>
      <circle class="val" cx="60" cy="60" r="50" stroke-dasharray="314" stroke-dashoffset="110" style="stroke:var(--purple)"></circle>
    </svg>
    <div class="lbl"><b>£720</b><span>{s.budgetLeft}</span></div>
  </div>
  <div class="num" style="font-size:.72rem;color:var(--muted)">£1,280 {s.budgetSpent}</div>
</div>
<div class="scr-card">
  <div class="bd-row"><div class="bd-top"><span>{s.bd2}</span><span class="num">£420</span></div><div class="bar"><i class="fill-orange" style="width:64%"></i></div></div>
</div>
<div class="scr-card">
  <div class="bd-row"><div class="bd-top"><span>{s.bd3}</span><span class="num">£180</span></div><div class="bar"><i class="fill-blue" style="width:38%"></i></div></div>
</div>
<ScreenNav active="bars" />
