---
import StoreBadges from "../StoreBadges.astro";
const { c, lang } = Astro.props as { c: any; lang: string };
const x = c.cta;
---
<section class="cta-final sec" id="cta">
  <div class="wrap cta-box reveal">
    <h2 class="l-h2">{x.head}</h2>
    <p>{x.sub}</p>
    <div class="hero-cta" style="margin-top:36px;justify-content:center">
      <StoreBadges lang={lang} />
    </div>
  </div>
</section>
