---
import Icon from "../Icon.astro";
const { c, lang } = Astro.props as { c: any; lang: string };
const f = c.features;
const base = `/${lang}`;
const iconMap: Record<string, string> = { check: "check", bill: "bill", goal: "ring", budget: "budget", grid: "grid", chart: "chart" };
---
<section class="sec wrap" id="features">
  <div class="sec-head reveal">
    <span class="eyebrow">{f.eyebrow}</span>
    <h2 class="l-h2 h2" style="margin-top:16px">{f.head}</h2>
    <p>{f.sub}</p>
  </div>
  <div class="feat-grid" data-stagger>
    {f.items.map((it: any) => (
      <article class="fcard">
        <span class={`fic ${it.tint}`}><Icon name={iconMap[it.icon]} /></span>
        <h3 class="l-h3">{it.t}</h3>
        <p>{it.d}</p>
        <a class="flink" href={`${base}/download`}><span>{f.link}</span><Icon name="arrow" class="dir" /></a>
      </article>
    ))}
  </div>
</section>
