---
// Footer — Calm Premium columns. Product / Company / Legal + credit line.
import Icon from "./landing/Icon.astro";
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const base = `/${lang}`;
const year = new Date().getFullYear();
const ar = lang === "ar";
const cols = [
  { h: ar ? "المنتج" : "Product", links: [
    { href: `${base}#features`, label: t("nav.features") },
    { href: `${base}/pricing`, label: t("nav.pricing") },
    { href: `${base}/download`, label: ar ? "التثبيت" : "Download" },
  ] },
  { h: ar ? "الشركة" : "Company", links: [
    { href: `${base}/about`, label: t("nav.about") },
    { href: "mailto:hello@savertrack.app", label: ar ? "تواصل" : "Contact" },
  ] },
  { h: ar ? "قانوني" : "Legal", links: [
    { href: `${base}/privacy-policy`, label: ar ? "سياسة الخصوصية" : "Privacy Policy" },
  ] },
];
const tagline = ar
  ? "ميزانية هادئة وخاصة تعمل بلا إنترنت. اعرف القابل للصرف — وادّخر بلا ضجيج."
  : "Calm, private, offline budgeting. See what's safe to spend — and save without the noise.";
---
<footer class="footer sec" style="padding-block:64px 40px">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <a class="brand" href={base}><span class="logo" aria-hidden="true"><Icon name="logo" /></span>Saver</a>
        <p>{tagline}</p>
      </div>
      {cols.map((col) => (
        <div class="foot-col">
          <h4>{col.h}</h4>
          {col.links.map((l) => (<a href={l.href}>{l.label}</a>))}
        </div>
      ))}
    </div>
    <div class="foot-bottom">
      <span>© {year} Saver · savertrack.app</span>
      <span class="sig">{ar ? "صُنع بعناية — محمود" : "Made with care by Mahmoud"}</span>
    </div>
  </div>
</footer>
