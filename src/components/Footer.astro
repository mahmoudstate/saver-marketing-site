---
// Footer — links, language switch, credit line (dynamic year).
import LangSwitch from "./LangSwitch.astro";
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const base = `/${lang}`;
const year = new Date().getFullYear();
const links = [
  { href: `${base}/pricing`, label: t("nav.pricing") },
  { href: `${base}/about`, label: t("nav.about") },
  { href: `${base}/privacy-policy`, label: lang === "ar" ? "سياسة الخصوصية" : "Privacy Policy" },
  { href: `${base}/download`, label: t("nav.download") },
];
---
<footer class="mt-24 border-t border-line/60">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-5 px-5 py-12">
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
      {links.map((l) => (
        <a href={l.href} class="text-sm font-bold text-muted transition-colors hover:text-text">{l.label}</a>
      ))}
    </div>
    <LangSwitch lang={lang} />
    <p class="text-center text-xs font-bold text-faint">{t("footer.rights")} © {year}</p>
  </div>
</footer>
