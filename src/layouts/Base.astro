---
// Base layout: sets <html lang/dir>, fonts, theme, SEO head, nav + footer.
import "../styles/global.css";
import "../styles/landing.css";
import "../styles/screen.css";
import Seo from "../components/Seo.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { dirFor } from "../i18n/utils";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  noindex?: boolean;
}
const { lang, title, description, noindex = false } = Astro.props;
const dir = dirFor(lang);
---

<!doctype html>
<html lang={lang} dir={dir} data-theme="dark" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/icon.png" />
    {/* No-flash theme bootstrap — runs before paint. A `?theme=` param (from
        an in-app deep link, e.g. the app's own Privacy card) wins over
        everything, including a stale saved choice from a past visit —
        otherwise the app can never actually hand off its current theme.
        Failing that: saved choice, then the OS's light/dark setting. */}
    <script is:inline>
      (function () {
        try {
          var fromLink = new URLSearchParams(location.search).get("theme");
          var t = fromLink === "light" || fromLink === "dark" ? fromLink
            : localStorage.getItem("saver-theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          if (fromLink) localStorage.setItem("saver-theme", t);
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>
    <Seo lang={lang} title={title} description={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body class="bg-bg text-text antialiased">
    <Navbar lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      import "../scripts/site.ts";
    </script>
  </body>
</html>
