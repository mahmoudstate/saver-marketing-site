---
// Landing page (Phase 1) — one long-scroll "Calm Premium" page, composed from
// small per-section components (see MARKETING_SITE_PLAN.md §6).
import Base from "../../layouts/Base.astro";
import { useTranslations, locales } from "../../i18n/utils";
import { landing } from "../../i18n/landing";
import type { Lang } from "../../i18n/ui";
import Hero from "../../components/landing/sections/Hero.astro";
import TrustBar from "../../components/landing/sections/TrustBar.astro";
import ProblemSolution from "../../components/landing/sections/ProblemSolution.astro";
import Features from "../../components/landing/sections/Features.astro";
import HowItWorks from "../../components/landing/sections/HowItWorks.astro";
import Privacy from "../../components/landing/sections/Privacy.astro";
import Bilingual from "../../components/landing/sections/Bilingual.astro";
import Gallery from "../../components/landing/sections/Gallery.astro";
import Testimonials from "../../components/landing/sections/Testimonials.astro";
import PricingTeaser from "../../components/landing/sections/PricingTeaser.astro";
import Faq from "../../components/landing/sections/Faq.astro";
import FinalCta from "../../components/landing/sections/FinalCta.astro";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const c = landing(lang);

// FAQPage structured data — eligible for the FAQ rich result in search.
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: c.faq.items.map((it: { q: string; a: string }) => ({
    "@type": "Question",
    name: it.q,
    acceptedAnswer: { "@type": "Answer", text: it.a },
  })),
};
---
<Base lang={lang} title={t("home.title")} description={t("home.desc")}>
  <Hero c={c} lang={lang} />
  <TrustBar c={c} />
  <ProblemSolution c={c} />
  <Features c={c} lang={lang} />
  <HowItWorks c={c} />
  <Privacy c={c} />
  <Bilingual c={c} />
  <Gallery c={c} />
  <Testimonials c={c} />
  <PricingTeaser c={c} lang={lang} />
  <Faq c={c} />
  <FinalCta c={c} lang={lang} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
