---
// Landing page (Phase 1) — one long-scroll page. Sections follow Section 6 of
// MARKETING_SITE_PLAN.md. These are labelled placeholders; the Calm Premium
// design (from Claude Design, "Saver" system) gets dropped into each section.
import Base from "../../layouts/Base.astro";
import { useTranslations } from "../../i18n/utils";
import { locales } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

// Section skeleton — id + heading. Fill with real design + copy next.
const sections = [
  { id: "hero", en: "Hero", ar: "الواجهة" },
  { id: "trust", en: "Trust bar", ar: "شريط الثقة" },
  { id: "problem", en: "Problem → Solution", ar: "المشكلة → الحل" },
  { id: "features", en: "Feature grid", ar: "المميزات" },
  { id: "how", en: "How it works", ar: "كيف يعمل" },
  { id: "privacy", en: "Privacy", ar: "الخصوصية" },
  { id: "bilingual", en: "Bilingual & multi-currency", ar: "لغتان وعملات متعددة" },
  { id: "gallery", en: "Screenshot gallery", ar: "معرض اللقطات" },
  { id: "testimonials", en: "Testimonials", ar: "آراء العملاء" },
  { id: "pricing", en: "Pricing teaser", ar: "لمحة الأسعار" },
  { id: "faq", en: "FAQ", ar: "الأسئلة الشائعة" },
  { id: "cta", en: "Final CTA", ar: "الدعوة الأخيرة" },
];
---
<Base lang={lang} title={t("home.title")} description={t("home.desc")}>
  <section class="mx-auto max-w-3xl px-5 py-20 text-center">
    <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">{t("site.tagline")}</h1>
    <p class="mt-5 text-lg font-semibold text-muted">{t("home.desc")}</p>
    <a href={`/${lang}/download`} class="mt-8 inline-block rounded-full bg-ac px-7 py-3 text-base font-extrabold text-ac-on shadow-soft">{t("cta.try")}</a>
  </section>

  {sections.slice(1).map((s) => (
    <section id={s.id} class="mx-auto max-w-6xl scroll-mt-20 border-t border-line/40 px-5 py-16">
      <p class="text-xs font-extrabold uppercase tracking-widest text-faint">Section · {s.id}</p>
      <h2 class="mt-2 text-2xl font-extrabold">{lang === "ar" ? s.ar : s.en}</h2>
      <p class="mt-3 text-sm text-muted">Placeholder — Calm Premium design + copy go here (see docs/MARKETING_SITE_PLAN.md §6).</p>
    </section>
  ))}
</Base>
