---
// Root — this is a static site (no server to read Accept-Language), so the
// visitor's language is detected client-side and they're bounced to /en/ or
// /ar/ before paint. <meta http-equiv="refresh"> is the no-JS/crawler fallback.
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      var lang = (navigator.language || "en").toLowerCase().startsWith("ar") ? "ar" : "en";
      location.replace("/" + lang + "/");
    </script>
    <meta http-equiv="refresh" content="0; url=/en/" />
  </head>
  <body></body>
</html>
